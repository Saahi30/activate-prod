# Supabase (Project Settings -> API in dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://ndelaniuexttuzfsmwil.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# anakin.io API key for scraping
ANAKIN_API_KEY=

# Slack incoming webhook (api.slack.com/apps -> Incoming Webhooks)
SLACK_WEBHOOK_URL=

# Groq API key (console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini "nano banana" — Gemini 2.5 Flash Image — for ad creative generation
# Get a key at https://aistudio.google.com/apikey  (also accepts GOOGLE_API_KEY)
# When unset, the WarRoom falls back to a procedural SVG mock so demos still work.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# Rainforest API (Amazon competitor discovery) — trajectdata.com/ecommerce/rainforest-api
RAINFOREST_API_KEY=
# Amazon domain to search against (default: amazon.in)
RAINFOREST_AMAZON_DOMAIN=amazon.in

# How often the worker polls each URL (seconds)
POLL_INTERVAL_SECONDS=30

# Country code for anakin proxy routing (use 'in' for India platforms)
ANAKIN_COUNTRY=in

# Use anakin headless browser (recommended for JS-heavy sites)
ANAKIN_USE_BROWSER=true

NEXT_PUBLIC_SUPABASE_URL=https://ndelaniuexttuzfsmwil.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon JWT>
SUPABASE_SERVICE_ROLE_KEY=<service_role JWT>

